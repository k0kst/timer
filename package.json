{
  "name": "bountytimer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BountyTimer — Focus. Earn. Rest. Repeat.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "VITE_BASE=/timer/ npm run build && rm -rf docs && cp -r dist docs && touch docs/.nojekyll && cp docs/index.html docs/404.html",
    "preview": "vite preview",
    "icons": "node scripts/gen-icons.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
