# Copy to .env and fill in. Never commit the real .env.

# DATABASE_URL
# Local dev: postgres://user:password@localhost:5432/bountytimer
#
# Supabase + an IPv4-only host (Render/Railway free tiers): you MUST use the
# "Session pooler" string, not the "Direct connection". The direct host
# (db.<ref>.supabase.co) is IPv6-only and unreachable from IPv4-only networks
# (symptom: "connect ENETUNREACH <ipv6-addr>:5432"). The session pooler is
# IPv4-reachable and looks like:
#   postgres://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://user:password@localhost:5432/bountytimer
JWT_SECRET=replace-with-a-long-random-string
PORT=4000
